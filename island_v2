
class IslandGame:

    def __init__(self):
        # number of lives the player has
        self.lives = 2
        print("Game started...")

    def start(self):
        # start of the adventure
        print("WELCOME TO MY ISLAND ☠️")
        print("You see 2 doors: red 🚪 and blue 🚪")

        door = input("Choose a door: ").lower()

        if door == "red":
            self.red_room()

        elif door == "blue":
            print("You enter a room with crocodiles 🐊")
            self.lose_life()

        else:
            print("Wrong choice ❌")

    def red_room(self):
        # player chooses a box in the red room
        print("Nice, you chose the red door")

        box = input("Choose a box (white, black, green): ").lower()

        if box == "green":
            print("You found the treasure 💰")

        elif box == "black":
            print("Snakes everywhere 🐍")
            self.lose_life()

        elif box == "white":
            print("Spiders attack 🕷️")
            self.lose_life()

        else:
            print("Invalid box")

    def lose_life(self):
        # decrease player life
        self.lives -= 1
        print("You lost a life!")
        print("Lives left:", self.lives)

        if self.lives <= 0:
            print("Game Over 💀")

game = IslandGame()
game.start()
